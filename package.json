{
  "name": "pi-copy-user-message",
  "version": "1.0.9",
  "description": "pi extension that adds /copy-user to copy the most recent user message to your clipboard",
  "author": "Mitch Fultz (https://github.com/fitchmultz)",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "extension",
    "clipboard",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fitchmultz/pi-copy-user-message.git"
  },
  "bugs": {
    "url": "https://github.com/fitchmultz/pi-copy-user-message/issues"
  },
  "homepage": "https://github.com/fitchmultz/pi-copy-user-message#readme",
  "scripts": {
    "test": "node --experimental-strip-types tests/copy-user-message.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm test && npm run typecheck",
    "prepublishOnly": "npm run check && npm pack --dry-run"
  },
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.2",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
